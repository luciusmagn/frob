#!/usr/bin/env -S sbcl --script

(require :asdf)

(let* ((launcher-path (truename *load-truename*))
       (bin-directory (uiop:pathname-directory-pathname launcher-path))
       (source-root (uiop:pathname-parent-directory-pathname bin-directory))
       (project-setup
         (or (let ((override (uiop:getenv "AUTOLITH_PROJECT_SETUP")))
               (and override (plusp (length override)) (pathname override)))
             (merge-pathnames ".qlot/setup.lisp" source-root)))
       (user-setup (merge-pathnames "quicklisp/setup.lisp"
                                    (user-homedir-pathname)))
       (quicklisp-setup (if (probe-file project-setup)
                           project-setup
                           user-setup))
       (protocol-output *standard-output*))
  (let ((*standard-output* *error-output*)
        (*trace-output* *error-output*))
    (unless (probe-file quicklisp-setup)
      (error "Autolith search needs Quicklisp at ~A" quicklisp-setup))
    (load quicklisp-setup)
    (uiop:symbol-call '#:ql '#:quickload :cffi :silent t)
    (asdf:load-asd (merge-pathnames "autolith.asd" source-root))
    (asdf:load-system :autolith))
  (uiop:symbol-call '#:autolith '#:search-worker-main protocol-output))

FROM rust:1.97.1-slim-bookworm@sha256:99e09cb2284e2ddbb73a995deee3e91783fd04d177602ccf6eab326d778ee777 AS rust-toolchain

FROM ubuntu:22.04@sha256:0e0a0fc6d18feda9db1590da249ac93e8d5abfea8f4c3c0c849ce512b5ef8982

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install --yes \
       bubblewrap build-essential ca-certificates cmake curl git \
       libssl-dev libz-dev libzstd-dev pkg-config \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=rust-toolchain /usr/local/cargo /usr/local/cargo
COPY --from=rust-toolchain /usr/local/rustup /usr/local/rustup
COPY build-in-container /usr/local/libexec/autolith-release-build

ENV CARGO_HOME=/usr/local/cargo \
    RUSTUP_HOME=/usr/local/rustup \
    RUSTUP_TOOLCHAIN=1.97.1 \
    PATH=/usr/local/cargo/bin:$PATH

ENTRYPOINT ["/bin/bash", "/usr/local/libexec/autolith-release-build"]
